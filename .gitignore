# OS Generated #
# ============ #

.DS_Store
.DS_Store?
._*
ehthumbs.db
[Tt]humbs.db
[Dd]esktop.ini


# =========================== #
# External Dependency Manager #
# =========================== #

# This may be different if it is changed in Android Resolver settings
Assets/GeneratedLocalRepo*


# ======== #
# FIREBASE #
# ======== #
# Source: https://github.com/firebase/quickstart-unity/issues/554#issuecomment-686876563

# From 'External Dependency Manager' (This may be different if it is changed in Android Resolver settings)
Assets/GeneratedLocalRepo*

Assets/StreamingAssets*
# Assets/StreamingAssets/google-services-desktop.json*
Assets/Plugins/Android/Firebase*

# Use the following one ONLY IF all aar files here are generated by Android Resolver.  Note that some Unity plugins does import libraries under this folder
# Assets/Plugins/Android/*.aar


# ============== #
# Odin Inspector #
# ============== #
# Source: https://odininspector.com/tutorials/getting-started/using-odin-with-source-control

# Ignore the auto-generated AOT compatibility dll.
/Assets/Plugins/Sirenix/Assemblies/AOT/*
# Ignore all unpacked demos.
/Assets/Plugins/Sirenix/Demos/*
# But keep the demo packages themselves.
!/Assets/Plugins/Sirenix/Demos/*.unitypackage


